# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real tokens.

# Discord bot token. Read at startup by src/main.rs::App::new().
# Create a bot at https://discord.com/developers/applications and grant it,
# on the announcement channel:
#   - View Channel
#   - Read Message History   (needed to fetch messages)
#   - Add Reactions          (needed for the auto-react poller)
# The app does NOT auto-load this file. Source it before running:
#   set -a; source .env; set +a; cargo run
# Or export inline:
#   DISCORD_BOT_TOKEN=... cargo run
DISCORD_BOT_TOKEN=
