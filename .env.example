# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real tokens.
#
# The app auto-loads .env on startup via dotenvy. If running under
# docker-compose, prefer the `env_file:` directive instead (or both — the
# ambient environment wins over .env).

# --- Discord ---------------------------------------------------------------

# Bot token. Create at https://discord.com/developers/applications and grant
# it, on the announcement channel:
#   - View Channel
#   - Read Message History   (needed to fetch messages)
#   - Add Reactions          (needed for the auto-react poller)
DISCORD_BOT_TOKEN=

# Target channel (the announcement channel). Defaults to the Mayo Jaune
# channel if unset. Find it by right-clicking the channel in Discord with
# Developer Mode enabled → Copy Channel ID.
DISCORD_CHANNEL_ID=981806074233507880

# Guild (server) the channel lives in. Only used to build a clickable
# "open in Discord" link in the UI — not used by the REST client.
DISCORD_GUILD_ID=981525647891525642

# --- App paths (optional) --------------------------------------------------

# Directory holding the post templates (`*_{km}.png`). Defaults to ./images
# when unset. Override this when running in a container with the assets
# mounted at a different path.
# DISCORD_TO_INSTA_IMAGES_DIR=/app/images

# Persistent state file (tracks last-reacted message ID per channel).
# Defaults to $XDG_CONFIG_HOME/discord_to_insta/state.json (or
# ~/.config/discord_to_insta/state.json). Override with a writable path
# inside the container or a volume-mounted file.
# DISCORD_TO_INSTA_STATE_PATH=/data/state.json

# --- Telegram (approval gate before Instagram) ----------------------------

# Telegram bot token from @BotFather. Both TELEGRAM_* vars must be set for
# the approval flow to activate; partial configuration disables it and
# logs a warning at startup.
TELEGRAM_BOT_TOKEN=

# Approval chat/group ID. For groups, this is a negative integer like
# -1001234567890. Add the bot to the group, promote it to admin, then use
# @RawDataBot (briefly added) or the get-chat JSON trick to get the ID.
TELEGRAM_APPROVAL_CHAT_ID=
